# ============================================================
#  PolyCards — variáveis de ambiente
#  Copie este arquivo para .env e preencha com seus valores.
#  NUNCA commit o arquivo .env — ele já está no .gitignore.
# ============================================================

# ------------------------------------------------------------------
# Firebase (frontend — valores públicos, sem risco de exposição)
#
# Como obter:
#   1. console.firebase.google.com → seu projeto → Configurações →
#      "Seus aplicativos" → ícone </> (Web) → copie o firebaseConfig
# ------------------------------------------------------------------
VITE_FIREBASE_API_KEY=COLE_AQUI
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=COLE_AQUI
VITE_FIREBASE_APP_ID=COLE_AQUI

# ------------------------------------------------------------------
# Stripe (frontend — apenas a chave PÚBLICA, começa com pk_)
#
# Como obter:
#   dashboard.stripe.com → Developers → API keys → Publishable key
# ------------------------------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_COLE_AQUI
